{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["main.py"],
      "cwd": "${workspaceRoot}/backend",
      "port": 8000
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--host"],
      "cwd": "${workspaceRoot}/frontend",
      "port": 5173
    }
  ]
}
