# ============================================================
# MES Kersten Backend Environment Configuration
# ============================================================
# SECURITY: This is an EXAMPLE file. DO NOT use these values in production!
# Copy this file to .env and update with your secure values.
#
# To create your .env file:
#   cp .env.example .env
#   Then edit .env with your actual secure values
# ============================================================

# ============================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
#
# SECURITY: Use a STRONG password (min 20 characters, random)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
DATABASE_URL=postgresql://mes_user:CHANGE_THIS_TO_A_SECURE_PASSWORD@localhost:5432/mes_kersten


# ============================================================
# JWT SECURITY (REQUIRED)
# ============================================================
# Secret key for JWT token signing
# MUST be at least 32 characters
#
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# SECURITY: NEVER commit the actual SECRET_KEY to git!
#
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# JWT Algorithm (HS256 is standard and secure)
ALGORITHM=HS256

# Token expiration in minutes (default: 24 hours = 1440 minutes)
# Adjust based on security requirements
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ============================================================
# ENVIRONMENT SETTINGS
# ============================================================
# Environment: development, staging, production
# Controls various security checks and behaviors
ENVIRONMENT=development

# Debug mode (MUST be False in production)
# Enables detailed error messages and SQL query logging
DEBUG=true


# ============================================================
# CORS CONFIGURATION
# ============================================================
# Allowed origins for CORS (comma-separated if multiple)
# For development: http://localhost:5173
# For production: https://your-domain.com
#
# SECURITY: NEVER use localhost origins in production!
#
CORS_ORIGINS=["http://localhost:5173"]


# ============================================================
# FILE STORAGE
# ============================================================
# Path for file storage (relative or absolute)
FILE_STORAGE_PATH=./data

# Maximum file size in bytes (default: 100MB)
MAX_FILE_SIZE=104857600


# ============================================================
# PRODUCTION EXAMPLE (uncomment and modify for production)
# ============================================================
# DATABASE_URL=postgresql://mes_production:VERY_SECURE_LONG_PASSWORD@db.example.com:5432/mes_kersten_prod
# SECRET_KEY=AWUpFLRrpqFJsiP1p9ZgxJ4CVScPdSZhHSZz9VjQV8fJ9J_z345IgR8SP3c_oyGj67AATe1RpqlevTGt2xNHkQ
# ENVIRONMENT=production
# DEBUG=false
# CORS_ORIGINS=["https://mes-kersten.example.com"]


# ============================================================
# QUICK SETUP GUIDE
# ============================================================
# 1. Copy this file: cp .env.example .env
#
# 2. Generate secure SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# 3. Set up PostgreSQL:
#    psql -U postgres
#    CREATE DATABASE mes_kersten;
#    CREATE USER mes_user WITH PASSWORD 'your_secure_password';
#    GRANT ALL PRIVILEGES ON DATABASE mes_kersten TO mes_user;
#    \q
#
# 4. Update .env with:
#    - Your PostgreSQL credentials in DATABASE_URL
#    - Your generated SECRET_KEY
#
# 5. Run migrations:
#    cd backend
#    python setup_database.py
#
# 6. Start the server:
#    python main.py
#
# ============================================================
# SECURITY CHECKLIST
# ============================================================
# ✓ SECRET_KEY is at least 64 characters random string
# ✓ DATABASE_URL uses strong password (20+ random characters)
# ✓ DEBUG=false in production
# ✓ ENVIRONMENT=production in production
# ✓ CORS_ORIGINS does not include localhost in production
# ✓ .env file is in .gitignore (never commit secrets!)
# ✓ File permissions: chmod 600 .env (readable only by owner)
# ============================================================
