[run]
# Coverage configuration for MES Kersten backend
source = .
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */venv/*
    */env/*
    */migrations/*
    */alembic/*
    */.pytest_cache/*
    */htmlcov/*
    setup.py
    conftest.py

[report]
# Reporting options
precision = 2
show_missing = True
skip_covered = False

# Fail if coverage is below threshold
fail_under = 70

exclude_lines =
    # Standard pragmas
    pragma: no cover

    # Don't complain about missing debug-only code
    def __repr__
    def __str__

    # Don't complain if tests don't hit defensive assertion code
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run
    if __name__ == .__main__.:

    # Don't complain about abstract methods
    @abstract
    @abc.abstractmethod

    # Don't complain about type checking blocks
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

[html]
directory = htmlcov
title = MES Kersten Backend Coverage Report
